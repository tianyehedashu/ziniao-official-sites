{
  "name": "乐天·联盟返利待确认",
  "description": "超级联盟返利待确认（pending）报表；使用当前标签页登录态调用 API。",
  "auth": {
    "type": "cookie",
    "hint": "需先在当前浏览器标签页登录 RMS（afl.rms.rakuten.co.jp）；请求会携带 Cookie",
    "show_hint": false
  },
  "navigate_url": "https://afl.rms.rakuten.co.jp/report/pending-daily",
  "mode": "fetch",
  "url": "https://afl.rms.rakuten.co.jp/api/report/pending?order={{order}}&offset={{offset}}&limit={{limit}}&date={{date}}",
  "method": "GET",
  "headers": {
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "Accept-Language": "ja",
    "Content-Type": "application/json",
    "X-Requested-With": "XMLHttpRequest"
  },
  "vars": {
    "date": {
      "type": "str",
      "required": true,
      "description": "目标月份 (YYYY-MM)",
      "example": "2026-03"
    },
    "offset": {
      "type": "int",
      "default": 0,
      "description": "偏移量（分页）"
    },
    "limit": {
      "type": "int",
      "default": 100,
      "description": "每页条数"
    },
    "order": {
      "type": "str",
      "default": "asc",
      "description": "排序：asc / desc"
    }
  }
}
