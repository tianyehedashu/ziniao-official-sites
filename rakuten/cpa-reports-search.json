{
  "name": "乐天·CPA 报表检索",
  "description": "CPA（按转化付费）广告报表检索；使用当前标签页登录态调用 API。",
  "auth": {
    "type": "xsrf",
    "hint": "需先在当前浏览器标签页登录 RMS（ad.rms.rakuten.co.jp）；请求会携带 Cookie 并从 Cookie 注入 X-XSRF-TOKEN",
    "show_hint": false
  },
  "navigate_url": "https://ad.rms.rakuten.co.jp/cpa/reports",
  "mode": "fetch",
  "url": "https://ad.rms.rakuten.co.jp/cpa/api/reports/search?page={{page}}&periodType={{period_type}}&startDate={{start_date}}&endDate={{end_date}}",
  "method": "GET",
  "headers": {
    "Accept": "application/json",
    "Accept-Language": "ja"
  },
  "header_inject": [{"header": "X-XSRF-TOKEN", "source": "cookie", "key": "XSRF-TOKEN"}],
  "vars": {
    "start_date": {
      "type": "str",
      "required": true,
      "description": "开始日 (YYYY-MM-DD)",
      "example": "2026-03-01"
    },
    "end_date": {
      "type": "str",
      "required": true,
      "description": "结束日 (YYYY-MM-DD)",
      "example": "2026-03-05"
    },
    "page": {
      "type": "int",
      "default": 1,
      "description": "页码"
    },
    "period_type": {
      "type": "int",
      "default": 2,
      "description": "周期类型：2=自定义区间"
    }
  }
}
