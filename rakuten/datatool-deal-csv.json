{
  "name": "乐天·DEAL 活动 CSV",
  "description": "DEAL 活动 CSV 下载；使用当前标签页登录态获取。",
  "auth": {
    "type": "cookie",
    "hint": "需先在当前浏览器标签页登录 RMS（datatool.rms.rakuten.co.jp）；请求会携带 Cookie",
    "show_hint": false
  },
  "navigate_url": "https://datatool.rms.rakuten.co.jp/datadownload",
  "mode": "fetch",
  "url": "https://datatool.rms.rakuten.co.jp/datadownload/get-csv/campaign?startDate={{start_date}}&endDate={{end_date}}&period={{period}}",
  "method": "GET",
  "headers": {
    "Accept": "*/*",
    "Accept-Language": "ja"
  },
  "vars": {
    "start_date": {
      "type": "str",
      "required": true,
      "description": "开始日 (YYYYMMDD)",
      "example": "20260301"
    },
    "end_date": {
      "type": "str",
      "required": true,
      "description": "结束日 (YYYYMMDD)",
      "example": "20260331"
    },
    "period": {
      "type": "str",
      "default": "daily",
      "description": "汇总粒度：daily / weekly / monthly"
    }
  }
}
