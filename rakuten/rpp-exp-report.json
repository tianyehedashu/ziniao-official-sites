{
  "name": "乐天·RPP 专家版报表",
  "description": "搜索联动型广告专家版（RPP-EXP）报表检索；使用当前标签页登录态调用 API。",
  "auth": {
    "type": "xsrf",
    "hint": "需先在当前浏览器标签页登录 RMS（ad.rms.rakuten.co.jp）；请求会携带 Cookie 并从 Cookie 注入 X-XSRF-TOKEN",
    "show_hint": false
  },
  "navigate_url": "https://ad.rms.rakuten.co.jp/rppexp/reports/",
  "mode": "fetch",
  "url": "https://ad.rms.rakuten.co.jp/rppexp/api/core/report",
  "method": "POST",
  "headers": {
    "Accept": "application/json",
    "Accept-Language": "ja",
    "Content-Type": "application/json",
    "page-id": "",
    "page-name": "rppexp_reports_",
    "x-shop-url": "{{shop_url}}"
  },
  "header_inject": [{"header": "X-XSRF-TOKEN", "source": "cookie", "key": "XSRF-TOKEN"}],
  "vars": {
    "start_date": {
      "type": "str",
      "required": true,
      "description": "开始日 (YYYY-MM-DD)",
      "example": "2026-03-01"
    },
    "end_date": {
      "type": "str",
      "required": true,
      "description": "结束日 (YYYY-MM-DD)",
      "example": "2026-03-05"
    },
    "shop_url": {
      "type": "str",
      "required": true,
      "description": "店铺 URL 路径段（slug），写入请求头 x-shop-url",
      "example": "pettena-collections"
    },
    "page_no": {
      "type": "int",
      "default": 1,
      "description": "页码"
    },
    "page_size": {
      "type": "int",
      "default": 30,
      "description": "每页条数"
    },
    "aggregation_period": {
      "type": "int",
      "default": 3,
      "description": "汇总周期：3=自定义"
    }
  },
  "body": {
    "pageNo": "{{page_no}}",
    "aggregationUnit": 1,
    "aggregationPeriod": "{{aggregation_period}}",
    "campaignSearchType": 1,
    "productSearchType": 1,
    "productRanking": 1,
    "allUser": true,
    "newCustomer": true,
    "existingCustomer": true,
    "impression": true,
    "clicks": true,
    "amountSpent": true,
    "cpc": true,
    "ctr": true,
    "h720": true,
    "gms": true,
    "roas": true,
    "cv": true,
    "cvr": true,
    "cpa": true,
    "aov": true,
    "startDate": "{{start_date}}",
    "endDate": "{{end_date}}",
    "pageSize": "{{page_size}}"
  }
}
