{
  "name": "乐天·广告购入明细",
  "description": "广告购买履历明细；使用当前标签页登录态调用 API。",
  "auth": {
    "type": "xsrf",
    "hint": "需先在当前浏览器标签页登录 RMS（ad.rms.rakuten.co.jp）；请求会携带 Cookie 并从 Cookie 注入 X-XSRF-TOKEN",
    "show_hint": false
  },
  "navigate_url": "https://ad.rms.rakuten.co.jp/shared/purchase_detail",
  "mode": "fetch",
  "url": "https://ad.rms.rakuten.co.jp/shared/api/purchase_detail?targetMonth={{target_month}}&period={{period}}&serviceTypeEcFlag={{flag_ec}}&serviceTypeGrpOrExFlag={{flag_grp}}&serviceTypeRppFlag={{flag_rpp}}&serviceTypeRppExpFlag={{flag_rpp_exp}}&serviceTypeCpaFlag={{flag_cpa}}&serviceTypeCaFlag={{flag_ca}}&serviceTypeTdaFlag={{flag_tda}}&serviceTypeTdaExpFlag={{flag_tda_exp}}&agreementYesFlag={{flag_agree_yes}}&agreementNoFlag={{flag_agree_no}}",
  "method": "GET",
  "headers": {
    "Accept": "application/json",
    "Accept-Language": "ja"
  },
  "header_inject": [{"header": "X-XSRF-TOKEN", "source": "cookie", "key": "XSRF-TOKEN"}],
  "vars": {
    "target_month": {
      "type": "str",
      "required": true,
      "description": "目标月份 (YYYY-MM)",
      "example": "2026-03"
    },
    "period": {
      "type": "int",
      "default": 1,
      "description": "周期：1=当月"
    },
    "flag_ec": {
      "type": "str",
      "default": "true",
      "description": "包含 EC 广告"
    },
    "flag_grp": {
      "type": "str",
      "default": "true",
      "description": "包含 GRP/EX 广告"
    },
    "flag_rpp": {
      "type": "str",
      "default": "true",
      "description": "包含 RPP 广告"
    },
    "flag_rpp_exp": {
      "type": "str",
      "default": "true",
      "description": "包含 RPP-EXP 广告"
    },
    "flag_cpa": {
      "type": "str",
      "default": "true",
      "description": "包含 CPA 广告"
    },
    "flag_ca": {
      "type": "str",
      "default": "true",
      "description": "包含 CA 广告"
    },
    "flag_tda": {
      "type": "str",
      "default": "true",
      "description": "包含 TDA 广告"
    },
    "flag_tda_exp": {
      "type": "str",
      "default": "true",
      "description": "包含 TDA-EXP 广告"
    },
    "flag_agree_yes": {
      "type": "str",
      "default": "true",
      "description": "包含已同意项"
    },
    "flag_agree_no": {
      "type": "str",
      "default": "true",
      "description": "包含未同意项"
    }
  }
}
