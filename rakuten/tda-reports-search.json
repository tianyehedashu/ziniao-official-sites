{
  "name": "乐天·TDA 报表检索",
  "description": "定向展示广告（TDA）报表检索；使用当前标签页登录态调用 API。",
  "auth": {
    "type": "xsrf",
    "hint": "需先在当前浏览器标签页登录 RMS（ad.rms.rakuten.co.jp）；请求会携带 Cookie 并从 Cookie 注入 X-XSRF-TOKEN",
    "show_hint": false
  },
  "navigate_url": "https://ad.rms.rakuten.co.jp/tda/performanceReport",
  "mode": "fetch",
  "url": "https://ad.rms.rakuten.co.jp/tda/api/aggregator/v2/reports/search?page={{page}}&campaignType={{campaign_type}}&selectionType={{selection_type}}&periodType={{period_type}}&reportStartDate={{start_date}}&reportEndDate={{end_date}}",
  "method": "GET",
  "headers": {
    "Accept": "application/json",
    "Accept-Language": "ja"
  },
  "header_inject": [{"header": "X-XSRF-TOKEN", "source": "cookie", "key": "XSRF-TOKEN"}],
  "vars": {
    "start_date": {
      "type": "str",
      "required": true,
      "description": "开始日 (YYYY-MM-DD)",
      "example": "2026-03-01"
    },
    "end_date": {
      "type": "str",
      "required": true,
      "description": "结束日 (YYYY-MM-DD)",
      "example": "2026-03-05"
    },
    "page": {
      "type": "int",
      "default": 1,
      "description": "页码"
    },
    "campaign_type": {
      "type": "int",
      "default": 1,
      "description": "推广计划类型：1=通常"
    },
    "selection_type": {
      "type": "int",
      "default": 1,
      "description": "汇总维度：1=按日"
    },
    "period_type": {
      "type": "int",
      "default": 3,
      "description": "周期类型：3=自定义"
    }
  }
}
